# ============================================================
# .gitignore — Proyecto Manejo / Nova Codice
# Cubre: Node.js, Python y Java
# ============================================================

# ==========================
# 🟢 NODE.JS
# ==========================
# Se ignoran porque son dependencias externas que se pueden
# reinstalar con `npm install`. Subirlas inflaría el repositorio
# innecesariamente (pueden pesar cientos de MB).
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.yarn/
.pnp.*

# Variables de entorno (pueden contener claves secretas o tokens)
.env
.env.local
.env.*.local

# Caché de herramientas Node
.npm/
.eslintcache
.parcel-cache/
dist/
build/

# ==========================
# 🐍 PYTHON
# ==========================
# Se ignoran porque son archivos generados automáticamente por
# el intérprete o por entornos virtuales locales que no deben
# compartirse entre desarrolladores.
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Entornos virtuales (cada desarrollador crea el suyo local)
venv/
env/
.venv/
.env/
ENV/

# Distribución y empaquetado
*.egg-info/
dist/
build/
.eggs/

# Pytest y cobertura
.pytest_cache/
.coverage
htmlcov/

# Jupyter Notebooks checkpoints
.ipynb_checkpoints/

# ==========================
# ☕ JAVA
# ==========================
# Se ignoran porque son archivos compilados (.class) o generados
# por el IDE/build tool. Solo el código fuente (.java) debe
# versionarse; los binarios cambian en cada compilación.
*.class
*.jar
*.war
*.ear
*.nar

# Directorios de compilación Maven y Gradle
target/
build/
out/
.gradle/
.mvn/

# Archivos de configuración de IDEs (IntelliJ, Eclipse)
.idea/
*.iml
.eclipse/
.settings/
.classpath
.project

# ==========================
# 🌐 GENERAL (todos los proyectos)
# ==========================
# Archivos del sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# Logs generales
*.log
logs/

# Archivos temporales
*.tmp
*.bak
*.swp
*.swo
*~

# Editores de código
.vscode/
*.code-workspace
